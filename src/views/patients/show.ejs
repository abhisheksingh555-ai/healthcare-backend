<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h2><i class="fas fa-user-injured"></i> <%= patient.name %></h2>
    <p class="subtitle">Patient Details</p>
  </div>
  <div class="btn-group">
    <a href="/patients/<%= patient.id %>/edit" class="btn btn-yellow"><i class="fas fa-edit"></i> Edit</a>
    <form action="/patients/<%= patient.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this patient?')">
      <button type="submit" class="btn btn-red"><i class="fas fa-trash"></i> Delete</button>
    </form>
    <a href="/patients" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</div>

<%- include('../partials/alerts') %>

<div class="detail-grid">
  <div class="detail-card">
    <h3><i class="fas fa-info-circle"></i> Personal Info</h3>
    <div class="detail-rows">
      <div class="detail-row"><span>Name</span><strong><%= patient.name %></strong></div>
      <div class="detail-row"><span>Age</span><strong><%= patient.age %> years</strong></div>
      <div class="detail-row"><span>Gender</span><strong><%= patient.gender %></strong></div>
      <div class="detail-row"><span>Contact</span><strong><%= patient.contact %></strong></div>
      <div class="detail-row"><span>Address</span><strong><%= patient.address || '—' %></strong></div>
      <div class="detail-row"><span>Registered</span><strong><%= new Date(patient.createdAt).toLocaleDateString() %></strong></div>
    </div>
  </div>

  <div class="detail-card">
    <h3><i class="fas fa-notes-medical"></i> Medical History</h3>
    <p class="medical-text"><%= patient.medical_history || 'No medical history recorded.' %></p>
  </div>
</div>

<div class="detail-card mt-4">
  <h3><i class="fas fa-user-md"></i> Assigned Doctors (<%= patient.assignedDoctors.length %>)</h3>
  <% if (patient.assignedDoctors.length === 0) { %>
    <p class="text-muted">No doctors assigned. <a href="/mappings">Assign a doctor</a></p>
  <% } else { %>
    <div class="chips">
      <% patient.assignedDoctors.forEach(d => { %>
        <a href="/doctors/<%= d.id %>" class="chip"><i class="fas fa-stethoscope"></i> Dr. <%= d.name %> – <%= d.specialization %></a>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>

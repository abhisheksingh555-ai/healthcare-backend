<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h2><i class="fas fa-user-md"></i> Dr. <%= doctor.name %></h2>
    <p class="subtitle"><%= doctor.specialization %></p>
  </div>
  <div class="btn-group">
    <a href="/doctors/<%= doctor.id %>/edit" class="btn btn-yellow"><i class="fas fa-edit"></i> Edit</a>
    <form action="/doctors/<%= doctor.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this doctor?')">
      <button type="submit" class="btn btn-red"><i class="fas fa-trash"></i> Delete</button>
    </form>
    <a href="/doctors" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</div>

<%- include('../partials/alerts') %>

<div class="detail-grid">
  <div class="detail-card">
    <h3><i class="fas fa-info-circle"></i> Doctor Info</h3>
    <div class="detail-rows">
      <div class="detail-row"><span>Name</span><strong>Dr. <%= doctor.name %></strong></div>
      <div class="detail-row"><span>Specialization</span><strong><%= doctor.specialization %></strong></div>
      <div class="detail-row"><span>Contact</span><strong><%= doctor.contact %></strong></div>
      <div class="detail-row"><span>Email</span><strong><%= doctor.email %></strong></div>
      <div class="detail-row"><span>Experience</span><strong><%= doctor.experience_years ? doctor.experience_years + ' years' : '—' %></strong></div>
      <div class="detail-row"><span>Added On</span><strong><%= new Date(doctor.createdAt).toLocaleDateString() %></strong></div>
    </div>
  </div>

  <div class="detail-card">
    <h3><i class="fas fa-user-injured"></i> Assigned Patients (<%= doctor.assignedPatients.length %>)</h3>
    <% if (doctor.assignedPatients.length === 0) { %>
      <p class="text-muted">No patients assigned to this doctor yet.</p>
    <% } else { %>
      <div class="chips">
        <% doctor.assignedPatients.forEach(p => { %>
          <a href="/patients/<%= p.id %>" class="chip"><i class="fas fa-user-injured"></i> <%= p.name %> (Age: <%= p.age %>)</a>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
